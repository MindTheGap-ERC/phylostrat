        #map_trees2 = storage.yoda(BASE_COLLECTION_STORAGE + "tree_{id}_nchar{nchar}_run_2_MAP.tre"),
        #map_tree = storage.yoda(BASE_COLLECTION_STORAGE + "tree_{id}_nchar{nchar}_MAP.tre")
    shell:
        """
        cp {input.num1} {output.num1}
        cp {input.trees1} {output.trees1}
        cp {input.num2} {output.num2}
        cp {input.trees2} {output.trees2}
        """