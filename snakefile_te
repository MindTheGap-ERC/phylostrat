        char_mat = storage.yoda(BASE_COLLECTION_SIM + "char_mat_{id}_nchar{nchar}_{case}_rho1.nex"),
        fossils = storage.yoda(BASE_COLLECTION_SIM + "fossils_{id}_nchar{nchar}_{case}_rho1.csv"),
        mol_dat = storage.yoda(BASE_COLLECTION_SIM + "mol_dat_{id}_nchar{nchar}_{case}_rho1.nex"),
        tree = storage.yoda(BASE_COLLECTION_SIM + "tree_{id}_nchar{nchar}_{case}_rho1.nex")
    input:
        char_mat = "data/sim/te/char_mat_{id}_nchar{nchar}_{case}_rho1.nex",
        fossils =  "data/sim/te/fossils_{id}_nchar{nchar}_{case}_rho1.csv",
        mol_dat = "data/sim/te/mol_dat_{id}_nchar{nchar}_{case}_rho1.nex",
        tree = "data/sim/te/tree_{id}_nchar{nchar}_{case}_rho1.nex"
    shell:
        """
        cp {input.char_mat} {output.char_mat}
