rule simulate_data_locally:
    output:
        expand("data/sim/te/char_mat_{id}_nchar{nchar}_{case}_rho1.nex", id = ID, nchar = NCHAR, case = CASE),
        expand("data/sim/te/fossils_{id}_nchar{nchar}_{case}_rho1.csv", id = ID, nchar = NCHAR, case = CASE),
        expand("data/sim/te/mol_dat_{id}_nchar{nchar}_{case}_rho1.nex", id = ID, nchar = NCHAR, case = CASE),
        expand("data/sim/te/tree_{id}_nchar{nchar}_{case}_rho1.nex", id = ID, nchar = NCHAR, case = CASE)
    shell:
        "Rscript code/te/sim_te.R"

