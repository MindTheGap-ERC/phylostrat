# snakefile for the total evidence analysis
NO_OF_REPLICAS = 10
#replica ID
ID = [str(i) for i in range(1, NO_OF_REPLICAS + 1)]
ID = ["1"]

#ID = ["1"]
NCHAR = ["100", "300", "1000"]
NRUNS_NUM = 2
NRUNS = str(NRUNS_NUM)
NRUN = [str(i) for i in range(1, NRUNS_NUM + 1)]
CASE = ["cont", "inc_A", "inc_B"]


BASE_COLLECTION_SIM = "irods://nluu11p/home/research-mindthegap/phylostrat/sim/te/"
BASE_COLLECTION_STORAGE = "irods://nluu11p/home/research-mindthegap/phylostrat/output/te/"

storage yoda:
    provider="irods",
    max_requests_per_second="1000"

rule all:
    input:
        numeric_skyline_A_full = storage.yoda(expand(BASE_COLLECTION_STORAGE + "num_skyline_A_full_te_{id}_{nchar}_run_{run}.log", run = NRUN, id = ID, nchar = NCHAR)),
        trees_skyline_A_full = storage.yoda(expand(BASE_COLLECTION_STORAGE + "trees_skyline_A_full_te_{id}_{nchar}_run_{run}.log", run = NRUN, id = ID, nchar = NCHAR)),
        map_skyline_A_full = storage.yoda(expand(BASE_COLLECTION_STORAGE + "trees_skyline_A_full_te_{id}_{nchar}_MAP.tre", id = ID, nchar = NCHAR)),
        maps_skyline_A_full = storage.yoda(expand( BASE_COLLECTION_STORAGE + "trees_skyline_A_full_te_{id}_{nchar}_run_{run}_MAP.tre", run = NRUN, id = ID, nchar = NCHAR)),
        numeric_skyline_A = storage.yoda(expand(BASE_COLLECTION_STORAGE + "num_skyline_A_te_{id}_{nchar}_run_{run}.log", run = NRUN, id = ID, nchar = NCHAR)),
        trees_skyline_A = storage.yoda(expand(BASE_COLLECTION_STORAGE + "trees_skyline_A_te_{id}_{nchar}_run_{run}.log", run = NRUN, id = ID, nchar = NCHAR)),
        map_skyline_A = storage.yoda(expand(BASE_COLLECTION_STORAGE + "trees_skyline_A_te_{id}_{nchar}_MAP.tre", id = ID, nchar = NCHAR)),
        maps_skyline_A = storage.yoda(expand( BASE_COLLECTION_STORAGE + "trees_skyline_A_te_{id}_{nchar}_run_{run}_MAP.tre", run = NRUN, id = ID, nchar = NCHAR)),
        numeric_cont = storage.yoda(expand(BASE_COLLECTION_STORAGE + "num_{case}_te_{id}_{nchar}_run_{run}.log", run = NRUN, id = ID, nchar = NCHAR, case = CASE)),
        trees_cont = storage.yoda(expand(BASE_COLLECTION_STORAGE + "trees_{case}_te_{id}_{nchar}_run_{run}.log", run = NRUN, id = ID, nchar = NCHAR, case = CASE)),
        map_cont = storage.yoda(expand(BASE_COLLECTION_STORAGE + "trees_{case}_te_{id}_{nchar}_MAP.tre", id = ID, nchar = NCHAR, case = CASE)),
        maps_cont = storage.yoda(expand( BASE_COLLECTION_STORAGE + "trees_{case}_te_{id}_{nchar}_run_{run}_MAP.tre", run = NRUN, id = ID, nchar = NCHAR, case = CASE))


rule fbd_analysis_te:
    params:
        numeric = storage.yoda(BASE_COLLECTION_STORAGE + "num_{case}_te_{id}_{nchar}"),
        trees = storage.yoda(BASE_COLLECTION_STORAGE + "trees_{case}_te_{id}_{nchar}")
    input:
        morph = storage.yoda(BASE_COLLECTION_SIM + "char_mat_{id}_nchar{nchar}_{case}_rho1.nex"),
        fossils = storage.yoda(BASE_COLLECTION_SIM + "fossils_{id}_nchar{nchar}_{case}_rho1.csv"),
        mol = storage.yoda(BASE_COLLECTION_SIM + "mol_dat_{id}_nchar{nchar}_{case}_rho1.nex"),
        start_tree = storage.yoda(BASE_COLLECTION_SIM + "tree_{id}_nchar{nchar}_{case}_rho1.nex")
    output:
        numeric = storage.yoda(expand(BASE_COLLECTION_STORAGE + "num_{{case}}_te_{{id}}_{{nchar}}_run_{run}.log", run = NRUN)),
        trees = storage.yoda(expand(BASE_COLLECTION_STORAGE + "trees_{{case}}_te_{{id}}_{{nchar}}_run_{run}.log", run = NRUN)),
        map = storage.yoda(BASE_COLLECTION_STORAGE + "trees_{case}_te_{id}_{nchar}_MAP.tre"),
        maps = storage.yoda(expand( BASE_COLLECTION_STORAGE + "trees_{{case}}_te_{{id}}_{{nchar}}_run_{run}_MAP.tre", run = NRUN))
    shell:
        "bash code/te/inference_fbd_te.sh {input.morph} {input.fossils} {input.mol} {params.numeric} {params.trees} {input.start_tree}"


